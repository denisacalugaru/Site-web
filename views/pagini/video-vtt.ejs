<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <title>Cum se realizează uu buchet la ScaiGarden</title>
  <style>
    .video-container {
      position: relative;
      width: 80%;
      max-width: 800px;
      min-width: 300px;
      padding-bottom: 56.25%; /* 16:9 */
      height: 0;
      overflow: hidden;
      margin: 20px auto;
    }

    .video-container video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    ::cue {
      background: rgba(255, 255, 255, 0.3);
      color: #222;
      font-size: 1.2em;
      text-align: center;
    }
  </style>
</head>
<body>
  <h1 style="text-align:center;">Cum se realizează uu buchet la ScaiGarden</h1>

  <div class="video-container">
    <video controls preload="metadata" poster="/resurse/imagini/poster.jpg">
      <source src="/resurse/video/buchet.mp4" type="video/mp4" />
      <source src="/resurse/video/buchet.webm" type="video/webm" />
      <track kind="subtitles" label="Română" srclang="ro" src="/resurse/video/ro.vtt" default />
      <track kind="subtitles" label="English" srclang="en" src="/resurse/video/en.vtt" />
      Your browser does not support the video tag.
    </video>
  </div>
</body>
</html>
